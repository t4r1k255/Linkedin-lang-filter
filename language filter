// ==UserScript==
// @name         linkedin için dil filtresi
// @name:en      Language filter for linkedin
// @namespace    https://github.com/t4r1k255/Linkedin-lang-filter
// @version      1.0.0
// @description  İş ilanlarını ve feed gönderilerini dil tespitine göre filtreler. İzin verilen dillerin dışındaki içerikleri gizler veya etiketler.
// @description:en Filters job listings and feed posts by detected language. Hides or labels content outside your allowed languages.
// @match        https://www.linkedin.com/*
// @grant        none
// @run-at       document-idle
// @noframes
// ==/UserScript==

(function () {
  'use strict';

  // ─── STORAGE ─────────────────────────────────────────────────────────────────
  const SK = 'lilf-settings';

  const DEFAULTS = {
    enabled: true,
    mode: 'hide',           // 'hide' | 'label'  — gizle veya etiket koy
    allowedLangs: ['tr', 'en'],
    minWords: 6,             // en az bu kadar kelime varsa tespit yap
    unknownAction: 'show',  // 'show' | 'hide' — dil tespit edilemezse ne yapılsın
  };

  function loadSettings() {
    try {
      const raw = localStorage.getItem(SK);
      if (!raw) return { ...DEFAULTS };
      return { ...DEFAULTS, ...JSON.parse(raw) };
    } catch { return { ...DEFAULTS }; }
  }

  function saveSettings() {
    try { localStorage.setItem(SK, JSON.stringify(settings)); } catch {}
  }

  let settings = loadSettings();

  // ─── DİL TESPİT MOTORü ───────────────────────────────────────────────────────
  // n-gram tabanlı hafif dil tanıma.
  // Her dil için en sık geçen trigram imzaları tanımlanmış.
  // Büyük model yok, ~5KB veri ile %85+ doğruluk (kısa metinlerde daha düşük).

  const LANG_PROFILES = {
    tr: ['bir','bir','ile','bir','için','bu','de','da','ve','nin','nın',
         'ler','lar','den','dan','ten','tan','nde','nda','ını','ini',
         'yor','mak','mek','dır','dir','tır','tir','rak','rek','ken',
         'ize','ize','yiz','yız','sın','sin','niz','nız','ler','lar'],
    en: ['the','and','ing','ion','tio','ent','for','tha','his','her',
         'are','was','has','not','you','all','can','had','but','our',
         'one','ork','ith','ter','ons','ati','ers','pro','com','out'],
    de: ['der','die','und','ein','ist','ich','das','den','mit','von',
         'ung','eit','sch','che','gen','nen','ten','ber','ver','auf',
         'sie','wie','hat','als','bei','zur','für','aber','sich','aus'],
    fr: ['les','des','est','une','que','qui','pas','sur','par','tout',
         'son','ses','aux','ous','ent','ion','ant','our','ait','eur',
         'ont','avec','dans','pour','plus','mais','elle','nous','vous','ces'],
    es: ['los','las','que','una','con','del','por','para','como','sus',
         'ción','ado','ado','nte','ión','ent','mos','nes','era','ado',
         'pero','este','esto','esta','son','ser','hay','más','tiene','años'],
    pt: ['que','uma','com','não','por','para','dos','das','são','mais',
         'ção','ado','nte','ões','ent','mos','res','ado','era','tos',
         'isso','este','esta','seus','suas','tem','ser','está','como','anos'],
    it: ['che','una','con','non','per','dei','delle','sono','come','più',
         'zione','ato','nte','ione','ent','amo','ono','ere','ato','tti',
         'questo','questa','hanno','essere','fare','anche','così','dopo','ogni','tra'],
    nl: ['van','het','een','zijn','voor','niet','met','dat','heeft','worden',
         'ing','aar','ijk','elijk','lijk','ien','den','ten','ver','aan',
         'maar','deze','wordt','door','over','jaar','naar','moet','kunnen','alle'],
    ru: ['что','это','как','для','его','она','они','все','так','при',
         'ого','ого','ние','ции','ать','ить','ный','ной','ого','ает',
         'ние','ием','ает','ить','ение','ости','ного','ных','ного','ских'],
    pl: ['nie','że','jak','dla','jego','jej','ich','ale','też','już',
         'nia','owi','ego','iem','ych','ość','iem','ają','uje','uje',
         'jest','tego','przez','może','będzie','oraz','sobie','tego','jako','który'],
    zh: ['的','了','是','在','我','有','和','就','不','都',
         '一个','这个','可以','我们','他们','什么','工作','公司','经验','技能'],
    ja: ['の','に','は','を','た','が','で','て','と','し',
         'する','いる','なる','ある','れる','できる','仕事','会社','経験','スキル'],
    ko: ['이','는','을','를','에','의','가','한','그','로',
         '하는','있는','위한','경력','회사','업무','지원','채용','스킬','팀'],
    ar: ['في','من','إلى','على','أن','كان','مع','هذا','لا','هو',
         'العمل','الشركة','الخبرة','المهارات','الفريق','التوظيف','المرشح','المتقدم','الوظيفة','يتطلب'],
  };

  // Metni normalize et, kelimelere ve trigramlara böl
  function extractNgrams(text, n) {
    const clean = text
      .toLowerCase()
      .replace(/https?:\/\/\S+/g, ' ')   // URL'leri çıkar
      .replace(/[^a-zçğıöşüA-ZÇĞIÖŞÜàáâãäåæçèéêëìíîïðñòóôõöùúûüýþßÀ-ÿа-яёА-ЯЁ\u0400-\u04FF\u0600-\u06FF\u3000-\u9FFF\uAC00-\uD7AF]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();

    const words  = clean.split(' ').filter(w => w.length > 1);
    const ngrams = [];

    for (const word of words) {
      if (word.length < n) { ngrams.push(word); continue; }
      for (let i = 0; i <= word.length - n; i++) {
        ngrams.push(word.slice(i, i + n));
      }
    }
    return { words, ngrams };
  }

  function detectLanguage(text) {
    if (!text || text.trim().length < 10) return null;

    const { words, ngrams } = extractNgrams(text, 3);
    if (words.length < settings.minWords) return null;

    const scores = {};
    let maxScore = 0;

    for (const [lang, profile] of Object.entries(LANG_PROFILES)) {
      const profileSet = new Set(profile);
      let score = 0;
      for (const ng of ngrams) {
        if (profileSet.has(ng)) score++;
      }
      // Normalize
      scores[lang] = ngrams.length > 0 ? score / ngrams.length : 0;
      if (scores[lang] > maxScore) maxScore = scores[lang];
    }

    if (maxScore < 0.04) return null; // Güven eşiği — altıysa belirsiz

    // En yüksek skoru bul
    const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
    const [bestLang, bestScore] = sorted[0];
    const [, secondScore]       = sorted[1] || [, 0];

    // İki dil arasındaki fark çok azsa belirsiz say
    if (bestScore - secondScore < 0.02) return null;

    return bestLang;
  }

  // ─── İÇERİK EXTRACTION ───────────────────────────────────────────────────────
  // İş kartından metin çıkar
  function getJobCardText(card) {
    const parts = [];
    const titleEl = card.querySelector(
      '.job-card-list__title, .base-search-card__title, ' +
      '[class*="job-title"], .artdeco-entity-lockup__title'
    );
    const descEl = card.querySelector(
      '.job-card-list__snippet, .base-search-card__metadata, ' +
      '[class*="snippet"], [class*="description"]'
    );
    if (titleEl) parts.push(titleEl.textContent || '');
    if (descEl)  parts.push(descEl.textContent || '');
    // Yeterli metin yoksa tüm kartı kullan (ilk 300 karakter)
    if (parts.join(' ').split(' ').length < 8) {
      parts.push((card.textContent || '').slice(0, 300));
    }
    return parts.join(' ').replace(/\s+/g, ' ').trim();
  }

  // Feed gönderisinden metin çıkar
  function getFeedPostText(post) {
    const textEl = post.querySelector(
      '.feed-shared-update-v2__description, ' +
      '.update-components-text, ' +
      '[class*="commentary"], ' +
      '[class*="update-content"]'
    );
    if (textEl) return (textEl.textContent || '').slice(0, 400).replace(/\s+/g, ' ').trim();
    return (post.textContent || '').slice(0, 400).replace(/\s+/g, ' ').trim();
  }

  // ─── SEÇICILER ───────────────────────────────────────────────────────────────
  const JOB_CARD_SELS = [
    '[data-occludable-job-id]',
    'li.jobs-search-results__list-item',
    'li.scaffold-layout__list-item',
    'li.discovery-templates-entity-item',
    'article.job-search-card',
    'div.base-card',
    'article.base-card',
  ].join(',');

  const FEED_POST_SELS = [
    'li.occludable-update',
    'div.feed-shared-update-v2',
    'div[data-urn*="activity"]',
  ].join(',');

  // ─── FİLTRELEME ──────────────────────────────────────────────────────────────
  function processElement(el, getText, type) {
    // Zaten işlenmiş mi?
    if (el.hasAttribute('data-lilf-done')) {
      syncVisibility(el);
      return;
    }

    const text = getText(el);
    const lang = detectLanguage(text);

    el.setAttribute('data-lilf-done', '1');
    el.setAttribute('data-lilf-type', type);

    if (!lang) {
      el.setAttribute('data-lilf-lang', 'unknown');
    } else {
      el.setAttribute('data-lilf-lang', lang);
    }

    syncVisibility(el);
  }

  function syncVisibility(el) {
    const lang    = el.getAttribute('data-lilf-lang') || 'unknown';
    const allowed = settings.allowedLangs;

    let shouldHide = false;

    if (lang === 'unknown') {
      shouldHide = settings.unknownAction === 'hide';
    } else {
      shouldHide = !allowed.includes(lang);
    }

    if (!settings.enabled) shouldHide = false;

    if (shouldHide && settings.mode === 'hide') {
      el.setAttribute('data-lilf-hidden', '1');
      el.removeAttribute('data-lilf-labeled');
    } else if (shouldHide && settings.mode === 'label') {
      el.removeAttribute('data-lilf-hidden');
      el.setAttribute('data-lilf-labeled', lang);
    } else {
      el.removeAttribute('data-lilf-hidden');
      el.removeAttribute('data-lilf-labeled');
    }
  }

  function processAll() {
    if (!isTargetPage()) { removeBadge(); return; }
    ensureBadge();

    // Önceki işaretleri sıfırla (ayarlar değiştiyse)
    document.querySelectorAll('[data-lilf-done]').forEach(el => {
      el.removeAttribute('data-lilf-done'); // yeniden tespit yaptır
    });

    // İş kartları
    if (isJobsPage()) {
      document.querySelectorAll(JOB_CARD_SELS).forEach(card => {
        processElement(card, getJobCardText, 'job');
      });
    }

    // Feed gönderileri
    if (isFeedPage()) {
      document.querySelectorAll(FEED_POST_SELS).forEach(post => {
        processElement(post, getFeedPostText, 'feed');
      });
    }

    updateBadge();
  }

  // Sayfa türü kontrolü
  function isJobsPage()   { return location.pathname.includes('/jobs'); }
  function isFeedPage()   {
    const p = location.pathname;
    return p === '/' || p === '/feed' || p === '/feed/' || p.startsWith('/feed/');
  }
  function isTargetPage() { return isJobsPage() || isFeedPage(); }

  // ─── DİL ETİKETİ (label modu) ────────────────────────────────────────────────
  // Dil adı etiketleri
  const LANG_NAMES = {
