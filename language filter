        #lilf-panel { right: 8px; width: calc(100vw - 16px); }
      }
    `;
  }

  // ─── ROZET ───────────────────────────────────────────────────────────────────
  let badge    = null;
  let countEl  = null;
  let modeEl   = null;

  function ensureBadge() {
    if (badge && document.body.contains(badge)) return;

    badge = document.createElement('div');
    badge.id = 'lilf-badge';

    countEl = document.createElement('span');
    countEl.className = 'lilf-count';
    countEl.textContent = '0';

    const lbl = document.createElement('span');
    lbl.className = 'lilf-lbl';
    lbl.textContent = 'filtrelendi';

    const sep = document.createElement('div');
    sep.className = 'lilf-sep';

    const toggleBtn = document.createElement('button');
    toggleBtn.type = 'button';
    toggleBtn.textContent = 'Dil Filtresi';
    toggleBtn.className = settings.enabled ? 'on' : '';
    toggleBtn.addEventListener('click', e => {
      e.stopPropagation();
      settings.enabled = !settings.enabled;
      saveSettings();
      toggleBtn.className = settings.enabled ? 'on' : '';
      processAll();
    });

    const manageBtn = document.createElement('button');
    manageBtn.type = 'button';
    manageBtn.textContent = '⚙ Ayarlar';
    manageBtn.className = 'manage';
    manageBtn.addEventListener('click', e => {
      e.stopPropagation();
      openPanel();
    });

    badge.appendChild(countEl);
    badge.appendChild(lbl);
    badge.appendChild(sep);
    badge.appendChild(toggleBtn);
    badge.appendChild(manageBtn);
    document.body.appendChild(badge);
  }

  function removeBadge() { badge?.remove(); badge = countEl = modeEl = null; }

  function updateBadge() {
    if (!countEl) return;
    const hidden  = document.querySelectorAll('[data-lilf-hidden]').length;
    const labeled = document.querySelectorAll('[data-lilf-labeled]').length;
    countEl.textContent = String(hidden + labeled);
  }

  // ─── YÖNETİM PANELİ ──────────────────────────────────────────────────────────
  const ALL_LANGS = [
    { code: 'tr', name: 'Türkçe' },
    { code: 'en', name: 'İngilizce' },
    { code: 'de', name: 'Almanca' },
    { code: 'fr', name: 'Fransızca' },
    { code: 'es', name: 'İspanyolca' },
    { code: 'pt', name: 'Portekizce' },
    { code: 'it', name: 'İtalyanca' },
    { code: 'nl', name: 'Hollandaca' },
    { code: 'ru', name: 'Rusça' },
    { code: 'pl', name: 'Lehçe' },
    { code: 'zh', name: 'Çince' },
    { code: 'ja', name: 'Japonca' },
    { code: 'ko', name: 'Korece' },
    { code: 'ar', name: 'Arapça' },
  ];

  let panel = null;

  function openPanel() {
    if (panel && document.body.contains(panel)) { closePanel(); return; }

    panel = document.createElement('div');
    panel.id = 'lilf-panel';

    panel.innerHTML = `
      <div class="lilf-ph">
        <span class="lilf-ph-title">Dil Filtresi Ayarları</span>
        <button class="lilf-ph-close" id="lilf-close">✕</button>
      </div>
      <div class="lilf-body">

        <div class="lilf-section">
          <div class="lilf-section-title">Filtre Modu</div>
          <div class="lilf-mode-group">
            <button class="lilf-mode-btn ${settings.mode === 'hide' ? 'active' : ''}"
              data-mode="hide">🚫 Gizle</button>
            <button class="lilf-mode-btn ${settings.mode === 'label' ? 'active' : ''}"
              data-mode="label">🏷 Etiketle</button>
          </div>
        </div>

        <div class="lilf-section">
          <div class="lilf-section-title">İzin Verilen Diller</div>
          <div class="lilf-lang-grid" id="lilf-lang-grid"></div>
        </div>

        <div class="lilf-section">
          <div class="lilf-section-title">Bilinmeyen Dil</div>
          <div class="lilf-row">
            <div>
              <div class="lilf-row-label">Tespit edilemeyen içerikleri gizle</div>
              <div class="lilf-row-sub">Dil belirlenemezse filtreye takılsın mı?</div>
            </div>
            <label class="lilf-toggle">
              <input type="checkbox" id="lilf-unknown-toggle"
                ${settings.unknownAction === 'hide' ? 'checked' : ''} />
              <div class="lilf-toggle-track"></div>
              <div class="lilf-toggle-thumb"></div>
            </label>
          </div>
        </div>

      </div>
      <div class="lilf-footer">
        <button id="lilf-apply">Uygula</button>
        <button id="lilf-reset">Sıfırla</button>
      </div>
    `;

    document.body.appendChild(panel);

    // Dil butonları
    const grid = document.getElementById('lilf-lang-grid');
    ALL_LANGS.forEach(({ code, name }) => {
      const btn = document.createElement('button');
      btn.className = 'lilf-lang-btn' + (settings.allowedLangs.includes(code) ? ' active' : '');
      btn.dataset.code = code;
      btn.title = name;
      btn.textContent = LANG_NAMES[code] + ' ' + name.slice(0, 3) + '.';
      btn.addEventListener('click', () => {
        btn.classList.toggle('active');
      });
      grid.appendChild(btn);
    });

    // Mod butonları
    panel.querySelectorAll('.lilf-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        panel.querySelectorAll('.lilf-mode-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    // Uygula
    document.getElementById('lilf-apply').addEventListener('click', () => {
      const activeMode = panel.querySelector('.lilf-mode-btn.active')?.dataset.mode || 'hide';
      const activeLangs = Array.from(panel.querySelectorAll('.lilf-lang-btn.active'))
        .map(b => b.dataset.code);
      const unknownHide = document.getElementById('lilf-unknown-toggle').checked;

      settings.mode         = activeMode;
      settings.allowedLangs = activeLangs;
      settings.unknownAction = unknownHide ? 'hide' : 'show';
      saveSettings();
      processAll();
      closePanel();
    });

    // Sıfırla
    document.getElementById('lilf-reset').addEventListener('click', () => {
      settings = { ...DEFAULTS };
      saveSettings();
      processAll();
      closePanel(); openPanel();
    });

    document.getElementById('lilf-close').addEventListener('click', closePanel);

    setTimeout(() => {
      document.addEventListener('click', outsideClick);
    }, 0);
  }

  function closePanel() {
    panel?.remove(); panel = null;
    document.removeEventListener('click', outsideClick);
  }

  function outsideClick(e) {
    if (panel && !panel.contains(e.target) && !e.target.closest('#lilf-badge')) closePanel();
  }

  // ─── OBSERVER & ZAMANLAYICILAR ────────────────────────────────────────────────
  let rafId    = null;
  let mutTimer = null;

  function scheduleRefresh() {
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(() => { rafId = null; processAll(); });
  }

  const observer = new MutationObserver(() => {
    if (mutTimer) return;
    mutTimer = setTimeout(() => { mutTimer = null; scheduleRefresh(); }, 250);
  });

  // ─── ROTA TAKİBİ ─────────────────────────────────────────────────────────────
  let lastPath = location.pathname;
  function onRouteChange() {
    if (location.pathname === lastPath) return;
    lastPath = location.pathname;
    setTimeout(scheduleRefresh, 400);
    setTimeout(scheduleRefresh, 1200);
  }
  function patchHistory(method) {
    const orig = history[method].bind(history);
    history[method] = function (...args) { const r = orig(...args); onRouteChange(); return r; };
  }

  // ─── BAŞLATMA ────────────────────────────────────────────────────────────────
  function init() {
    injectCSS();
    if (isTargetPage()) {
      ensureBadge();
      scheduleRefresh();
      setTimeout(scheduleRefresh, 800);
      setTimeout(scheduleRefresh, 2200);
    }
    observer.observe(document.body, { childList: true, subtree: true });
    patchHistory('pushState');
    patchHistory('replaceState');
    window.addEventListener('popstate', onRouteChange);
    setInterval(() => { if (isTargetPage()) scheduleRefresh(); }, 3000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }

})();
