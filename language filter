        display: flex; flex-direction: column;
        max-height: calc(100vh - 140px);
        overflow: hidden;
      }
      .lilf-ph {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 14px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.09); flex-shrink: 0;
      }
      .lilf-ph-title { font-size: 13px; font-weight: 600; color: #d0dce8; }
      .lilf-ph-close {
        background: none; border: none; color: #6e8090; cursor: pointer;
        font-size: 14px; padding: 2px 6px; border-radius: 6px;
      }
      .lilf-ph-close:hover { color: #c8d8e4; background: rgba(255,255,255,0.08); }

      .lilf-body { flex: 1; overflow-y: auto; padding: 12px 14px; }
